LAB 7
Pre-setup (Run first)
sudo apt update
sudo apt install -y hydra hashcat john medusa wordlists
sudo gunzip /usr/share/wordlists/rockyou.txt.gz
sudo service ssh start
echo -n "password123" | md5sum | awk '{print $1}' > hash.txt

Hydra (Online SSH brute force)
hydra -l admin -P /usr/share/wordlists/rockyou.txt -t 4 -V 127.0.0.1 ssh

John the Ripper (Offline hash cracking)
john --wordlist=/usr/share/wordlists/rockyou.txt hash.txt
john --show hash.txt

Hashcat (GPU hash cracking)
hashcat -m 0 -a 0 hash.txt /usr/share/wordlists/rockyou.txt
hashcat -m 0 hash.txt --show

Medusa (Online SSH brute force)
medusa -h 127.0.0.1 -u admin -P /usr/share/wordlists/rockyou.txt -M ssh

Extra Hashcat modes (for different hash types)
# MD5 (mode 0)
hashcat -m 0 -a 0 hash.txt /usr/share/wordlists/rockyou.txt

# SHA1 (mode 100)
echo -n "password123" | sha1sum | awk '{print $1}' > sha1_hash.txt
cat sha1_hash.txt
hashcat -m 100 -a 0 sha1_hash.txt /usr/share/wordlists/rockyou.txt
hashcat -m 100 sha1_hash.txt --show


# SHA256 (mode 1400)
echo -n "password123" | sha256sum | awk '{print $1}' > sha256_hash.txt
hashcat -m 1400 -a 0 sha256_hash.txt /usr/share/wordlists/rockyou.txt
hashcat -m 1400 sha256_hash.txt --show


